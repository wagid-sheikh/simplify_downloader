# Ensure cron can find Poetry (installed in user-local bin)
CRON_PATH="/Users/wagidsheikh/.local/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin"
CRON_HOME="/Users/wagidsheikh"

# Fail cron Script 1 when the orders profiler persists overall_status=failed.
# Keep this enabled in production so failed profiler summaries are visible to cron.
ORDERS_SYNC_PROFILER_FAIL_ON_FAILED_STATUS=1

# Recommended production retry policy for erratic internet / transient CRM issues.
# Deterministic code errors still fail fast in cron_run_orders_and_reports.sh via
# is_deterministic_code_error, so these retries are meant for web/network flakes.
ORDERS_MAX_ATTEMPTS=3
ORDERS_RETRY_DELAY_SECONDS=30
ORDERS_RETRY_BACKOFF_MULTIPLIER=2
ORDERS_RETRY_MAX_DELAY_SECONDS=300
ORDERS_RETRY_JITTER_SECONDS=10

# Report retries. These are less network-sensitive than the orders profiler but
# keep limited retries for transient DB/email/report generation hiccups.
DAILY_MAX_ATTEMPTS=3
DAILY_RETRY_DELAY_SECONDS=10
PENDING_MAX_ATTEMPTS=3
PENDING_RETRY_DELAY_SECONDS=10
MTD_SAME_DAY_MAX_ATTEMPTS=3
MTD_SAME_DAY_RETRY_DELAY_SECONDS=10
# TD-leads watchdog. The deprecated generic MAX_RUNTIME_SECONDS may still be
# supplied as a direct compatibility override and takes precedence when set.
TD_LEADS_MAX_RUNTIME_SECONDS=300

# Pipeline-local single-flight recovery policy. TD leads uses only
# tmp/cron_run_td_leads_sync.lock; orders/reports uses only
# tmp/cron_run_orders_and_reports.lock. The two pipelines may overlap. A new
# invocation never bypasses a healthy same-pipeline owner: it logs a visible
# suppression and exits quickly. Dead owners are cleaned up, while owners older
# than the configured threshold are terminated by process group, verified gone,
# and replaced after strict PID/PGID and wrapper-command validation. Wrappers
# relaunch into dedicated sessions before recording lock metadata. The 12-hour
# orders/reports threshold exceeds the default ~8h04m watchdog/retry envelope;
# raise it together with any larger retry or watchdog configuration. Meeting-mode
# and day-end TD-leads runs use this same TD local-lock recovery policy.
TD_LEADS_STALE_OWNER_SECONDS=300
ORDERS_REPORTS_STALE_OWNER_SECONDS=43200
STALE_OWNER_TERM_WAIT_SECONDS=5
STALE_OWNER_KILL_WAIT_SECONDS=5
